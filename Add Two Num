import java.util.Scanner; // Import the Scanner class to read input

public class AddTwoNumbers {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in); // Create a Scanner object for input

        System.out.println("Enter first number:");
        int num1 = scanner.nextInt(); // Read user input and store in variable num1

        System.out.println("Enter second number:");
        int num2 = scanner.nextInt(); // Read user input and store in variable num2

        int sum = num1 + num2; // Calculate the sum

        System.out.println("The sum is: " + sum); // Print the sum

        scanner.close(); // Close the scanner
    }
}
